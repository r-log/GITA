# ===========================================
# GitHub Assistant — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- GitHub App ---
# Get these from: GitHub > Settings > Developer Settings > GitHub Apps > Your App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# --- Database ---
DATABASE_URL=postgresql+asyncpg://github_assistant:password@localhost:5432/github_assistant

# --- Redis (for background task queue) ---
REDIS_URL=redis://localhost:6379

# --- AI Provider (OpenRouter) ---
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Default model for agents (can be overridden per-agent)
# Popular choices: openai/gpt-4o, anthropic/claude-sonnet-4, meta-llama/llama-3.1-70b
AI_DEFAULT_MODEL=openai/gpt-4o

# --- Cloudflare Tunnel ---
# Only needed if using Cloudflare Tunnel for webhook delivery
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# --- App Settings ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# Write-mode gate — controls whether agent decisions mutate GitHub state.
#   shadow  = log only, never execute (DEFAULT — safe for development)
#   comment = execute comments, downgrade everything else to a comment
#   full    = execute anything that passes its confidence threshold
# NEVER commit this file with WRITE_MODE=comment or =full.
# Only flip deliberately for one-shot Day-7-style live runs, then flip back.
WRITE_MODE=shadow

# Webhook URL (set this in your GitHub App settings)
# If using Cloudflare Tunnel: https://gh-assistant.yourdomain.com/api/webhooks/github
# If local dev with smee.io: https://smee.io/your-channel-id
WEBHOOK_PROXY_URL=
